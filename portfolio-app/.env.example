# ============================================
# Portfolio Manager - Environment Variables
# ============================================
# Copy this file to .env.local for development
# or .env for Docker production

# --- Database ---
DATABASE_URL="file:./prisma/portfolio.db"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# --- Seed user (run: npm run db:seed) ---
SEED_EMAIL="admin@family.local"
SEED_PASSWORD="change-me-in-production"
SEED_NAME="Admin"

# --- Market Data ---
# Yahoo Finance (free, no key required - used via yfinance-compatible endpoint)
YAHOO_FINANCE_BASE_URL="https://query1.finance.yahoo.com/v8/finance/chart"

# --- FX Rates (free tier) ---
# Option A: exchangerate-api.com (free tier: 1500 req/month)
EXCHANGE_RATE_API_KEY="your-exchangerate-api-key"
# Option B: fixer.io (alternative)
# FIXER_API_KEY="your-fixer-key"

# --- AI Insights ---
# Pluggable: set provider to "openai", "anthropic", or "mock"
AI_PROVIDER="mock"
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# --- App Config ---
APP_NAME="Family Portfolio Manager"
APP_URL="http://localhost:3000"
